OPENAI_API_KEY=your-key-here

# PortOne (server)
PORTONE_API_SECRET=
PORTONE_STORE_ID=

# PortOne channels (server routes return these to client)
# Primary channels (set to KG이니시스 or NHN KCP channelKey values)
PORTONE_CHANNEL_KEY_ONETIME=
PORTONE_CHANNEL_KEY_BILLING=

# NHN KCP specific channels (optional - used if primary keys not set)
PORTONE_CHANNEL_KEY_KCP_ONETIME=
PORTONE_CHANNEL_KEY_KCP_BILLING=

# KG이니시스 specific channels (optional fallback)
PORTONE_CHANNEL_KEY_INICIS_ONETIME=
PORTONE_CHANNEL_KEY_INICIS_BILLING=

# Backward-compat legacy key (optional)
PORTONE_CHANNEL_KEY_TOSS=
